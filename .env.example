# =====================================================================
# .env.example
# Copy to .env (or set as Airflow Variables/Connections) — never commit
# real credentials. Referenced by extract/, load/, and dbt profiles.
# =====================================================================

# ---- Source Postgres ----
PG_HOST=source-postgres.internal
PG_PORT=5432
PG_DATABASE=app_db
PG_USER=etl_reader
PG_PASSWORD=

# ---- Redshift ----
RS_HOST=my-redshift-cluster.xxxx.redshift.amazonaws.com
RS_PORT=5439
RS_DATABASE=analytics
RS_USER=etl_user
RS_PASSWORD=

# ---- S3 ----
S3_RAW_BUCKET=my-company-dwh-raw

# IAM role attached to / assumable by Redshift for COPY FROM S3
REDSHIFT_COPY_IAM_ROLE=arn:aws:iam::123456789012:role/RedshiftCopyRole

# AWS credentials for boto3 (prefer an instance profile / IRSA over keys)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-south-1
