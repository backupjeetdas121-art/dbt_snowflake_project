# Auto normalize line endings for all text files
* text=auto

# Python files
*.py text eol=lf

# Shell scripts
*.sh text eol=lf
*.bash text eol=lf

# Windows batch files
*.bat text eol=crlf
*.cmd text eol=crlf

# Markdown
*.md text eol=lf

# YAML / Config
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.toml text eol=lf

# SQL
*.sql text eol=lf

# Docker
Dockerfile text eol=lf
.dockerignore text eol=lf

# Git
.gitignore text eol=lf
.gitattributes text eol=lf

# Binary files
*.parquet binary
*.pkl binary
*.db binary
